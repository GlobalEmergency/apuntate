{% extends 'email/base.html.twig' %}

{% block title %}Bienvenido a Apúntate{% endblock %}

{% block content %}
    <h2 style="margin: 0 0 16px; color: #212529; font-size: 22px; font-weight: 600;">
        ¡Bienvenido, {{ user.name }}!
    </h2>

    <p style="margin: 0 0 16px; color: #495057; font-size: 15px; line-height: 1.6;">
        Tu organización <strong>{{ organization.name }}</strong> ha sido creada correctamente en Apúntate.
    </p>

    <p style="margin: 0 0 24px; color: #495057; font-size: 15px; line-height: 1.6;">
        Ya puedes acceder al panel de administración para configurar tus unidades, crear servicios e invitar a los miembros de tu equipo.
    </p>

    <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto 24px;">
        <tr>
            <td style="background-color: #3f51b5; border-radius: 8px;">
                <a href="{{ loginUrl }}" style="display: inline-block; padding: 14px 32px; color: #ffffff; text-decoration: none; font-size: 15px; font-weight: 600;">
                    Acceder a Apúntate
                </a>
            </td>
        </tr>
    </table>

    <p style="margin: 0; color: #868e96; font-size: 13px; line-height: 1.5;">
        Si no has creado esta cuenta, puedes ignorar este mensaje.
    </p>
{% endblock %}
