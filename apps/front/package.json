    "@types/uuid": "^9.0.8",
    "angular-eslint": "^19.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
