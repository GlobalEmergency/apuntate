{
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "apps/front/src/**/*.{ts,html}": [
      "prettier --write --config apps/front/.prettierrc"
    ],
    "apps/front/src/**/*.scss": [
      "prettier --write --config apps/front/.prettierrc"
    ],
    "apps/back/src/**/*.php": [
      "docker compose exec -T php-fpm php -dxdebug.mode=off vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --path-mode=intersection"
    ]
  }
}
